{
  "name": "daily-news",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "tsx scripts/newsServer.ts",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "serve": "npm run build && tsx scripts/newsServer.ts",
    "test": "vitest run",
    "generate": "tsx scripts/generateDailyNews.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "firecrawl": "^4.6.0",
    "lucide-react": "^0.561.0",
    "vite": "^7.3.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "vitest": "^4.0.16"
  }
}
